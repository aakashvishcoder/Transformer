{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Kill tensor.exe",
            "type": "shell",
            "command": "taskkill /f /im tensor.exe 2>nul || exit 0",
            "windows": {
                "command": "taskkill /f /im tensor.exe 2>nul || exit 0"
            },
            "problemMatcher": []
        },
        {
            "label": "Build C++ LLM",
            "type": "shell",
            "command": "g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${workspaceFolder}/tensor.cpp",
                "-o",
                "${workspaceFolder}/tensor.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": ["Kill tensor.exe"],
            "problemMatcher": "$gcc"
        }
    ]
}